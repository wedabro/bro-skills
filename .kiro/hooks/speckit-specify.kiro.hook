{
  "enabled": true,
  "name": "Speckit: Specify",
  "description": "Tạo spec.md từ mô tả feature theo .agent/workflows/02-speckit.specify.md",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Đọc và thực thi `.agent/workflows/02-speckit.specify.md`. Hỏi tôi mô tả feature nếu chưa có, rồi tạo `.agent/specs/[feature]/spec.md`. Tuân thủ `.agent/memory/constitution.md`. Phản hồi bằng Tiếng Việt."
  }
}