{
  "enabled": true,
  "name": "Speckit: Constitution",
  "description": "Thiết lập/cập nhật luật dự án theo .agent/workflows/01-speckit.constitution.md",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Đọc và thực thi `.agent/workflows/01-speckit.constitution.md`. Cập nhật `.agent/memory/constitution.md`. Phản hồi bằng Tiếng Việt."
  }
}